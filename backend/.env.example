# Backend configuration — copy to `.env` and fill in real values.
#
#   cp .env.example .env
#
# `.env` is gitignored; never commit real secrets. In production these values do
# NOT come from a file — they come from your platform's secret store (e.g. AWS
# SSM Parameter Store / Secrets Manager), injected as environment variables.
# The Go code reads os.Getenv either way, so the binary is identical dev↔prod.

# --- Server ---
PORT=8080

# --- Session signing (REQUIRED in prod) ---
# Any long random string. Dev may use a throwaway; prod MUST be a real secret.
SESSION_SECRET=dev-insecure-secret-change-me

# --- Google "Sign in with Google" ---
# The OAuth 2.0 *Web application* client ID from Google Cloud Console. The backend
# calls tokeninfo on the access token and rejects it unless its `aud`/`azp` equals
# this value (proof the token was minted for us). Leave empty to disable the check
# (dev only). Dev and prod normally use DIFFERENT clients (localhost origin vs your
# real domain), so this value differs per environment.
GOOGLE_CLIENT_ID=

# --- DynamoDB ---
# Local dev with DynamoDB Local: set the endpoint below (run `docker compose up`).
# To use the in-memory seeded repo instead (no DB needed), leave DYNAMODB_ENDPOINT
# and AWS_REGION unset. Production: leave DYNAMODB_ENDPOINT unset and set a real
# AWS_REGION so the SDK talks to real DynamoDB.
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=local
USERS_TABLE=Users
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- Facebook "Continue with Facebook" ---
# The backend confirms each token belongs to our app via Graph debug_token, which
# needs an app access token ("{APP_ID}|{APP_SECRET}"). Set BOTH to enable the check;
# leave either empty to disable it (dev only). Unlike GOOGLE_CLIENT_ID, the App
# Secret is a real secret — keep it out of the frontend and out of git. Dev and prod
# use different apps, so these differ per environment.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

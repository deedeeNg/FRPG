# Frontend build-time config. Copy to `.env` and fill in. Vite only exposes
# variables prefixed with VITE_ to the browser, and these are PUBLIC client
# identifiers (safe to ship) — never put secrets (e.g. an App Secret) here.

# Google OAuth *client ID* (type: Web application). Same value the backend used to
# read as GOOGLE_CLIENT_ID. For the local popup to work, add http://localhost:5173
# to this client's "Authorized JavaScript origins" in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=

# Facebook *App ID* (public — NOT the App Secret). The app must have Facebook Login
# and the `email` permission enabled, or the token carries no email and the backend
# rejects it with 401.
VITE_FACEBOOK_APP_ID=

# Where the vite dev proxy forwards /api and /auth. Defaults to http://localhost:8080;
# docker-compose overrides it with http://backend:8080.
# VITE_API_TARGET=http://localhost:8080
